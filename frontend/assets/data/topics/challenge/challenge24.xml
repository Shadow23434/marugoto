				<ro><first>B) Mai:</first><second>Mainichi shichi-ji ni okimasu.</second></ro>
				<en><first>B) Mai:</first><second>I get up at 7 o'clock.</second></en>
				<es><first>B) Mai:</first><second>Me levanto a las 7. </second></es>
			</cue>

			
			<cue time="12.1" person="A">
