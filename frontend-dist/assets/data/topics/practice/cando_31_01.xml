	<challenge type="basic">
		<video src="./asset/31/challenge_">
			<cue time="0" person="">
				<ja></ja>
				<ro></ro>
				<en></en>
				<es></es>
			</cue>

			
			<cue time="1.0" person="A">
				<ja><first>としこさん、まいさんと　でかける　やくそくを　しましょう。</first></ja>
				<ro><first>Toshiko-san, Mai-san to dekakeru yakusoku o shimashoo.</first></ro>
				<en><first>Arrange to go out with Toshiko and Mai.</first></en>
				<es><first>Fija una cita para salir con Mai y Toshiko.</first></es>
			</cue>

			
			<cue time="6.0" person="A">
				<ja><first>そういえば…</first></ja>
				<ro><first>Soo ieba…</first></ro>
				<en><first>Speaking of days off…</first></en>
				<es><first>Hablando de días libres... </first></es>
			</cue>

			
			<cue time="8.0" person="A">
				<ja><first>これこれ。こんど　きものショーが　あります。</first></ja>
				<ro><first>Kore kore. Kondo kimono-shoo ga arimasu.</first></ro>
				<en><first>Here it is. There's a kimono show soon.</first></en>
				<es><first>Aquí está. Va a haber un espectáculo de quimonos pronto. </first></es>
			</cue>

			
			<cue time="13.5" person="A">
				<ja><first>いっしょに　いきませんか。</first></ja>
				<ro><first>Issho ni ikimasen ka.</first></ro>
				<en><first>Do you want to go with us?</first></en>
				<es><first>¿No quieres ir con nosotros?</first></es>
			</cue>

			
			<cue time="17.0" person="A">
				<ja><first>いつ?</first></ja>
				<ro><first>Itsu?</first></ro>
				<en><first>Ask when the kimono show is.</first></en>
				<es><first>Pregunta cuándo es el espectáculo de quimonos.</first></es>
			</cue>

			
			<cue time="22.5" person="B">
				<ja><first>いつですか。</first></ja>
				<ro><first>Itsu desu ka.</first></ro>
				<en><first>When is it?</first></en>
				<es><first>¿Cuándo es?</first></es>
			</cue>

			
			<cue time="28.2" person="A">
				<ja><first>5月3日です。</first></ja>
				<ro><first>Go-gatsu mikka desu.</first></ro>
				<en><first>It's on May 3rd.</first></en>
				<es><first>Es el 3 de mayo.</first></es>
			</cue>

			
			<cue time="31.0" person="A">
				<ja><first>わたしは　まいと　見に　いきます。いっしょに　いきませんか。</first></ja>
				<ro><first>Watashi wa Mai to mi ni ikimasu. Issho ni ikimasen ka.</first></ro>
				<en><first>I'm going to see it with Mai. Do you want to go too?</first></en>
				<es><first>Voy a ir a verlo con Mai. ¿Quieres ir tú también?</first></es>
			</cue>

			
			<cue time="40.0" person="A">
				<ja><first>いきましょう。</first></ja>
				<ro><first>Ikimashoo.</first></ro>
				<en><first>Let's go!</first></en>
				<es><first>Vamos.</first></es>
			</cue>

			
			<cue time="45.5" person="B">
				<ja><first>いいですね。いきましょう。</first></ja>
				<ro><first>Ii desu ne. Ikimashoo.</first></ro>
				<en><first>Sounds good. Let's go.</first></en>
				<es><first>Suena interesante. Vamos.</first></es>
			</cue>

			
			<cue time="51.0" person="A">
